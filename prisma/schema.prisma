// MotorNews Global — schema do banco de dados
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ArticleStatus {
  PUBLISHED
  HIDDEN
  DRAFT
}

model Source {
  id        String   @id @default(cuid())
  name      String
  url       String   @unique
  rssUrl    String?
  country   String
  language  String
  category  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]

  @@index([country])
  @@index([category])
  @@index([active])
}

model Article {
  id              String        @id @default(cuid())
  sourceId        String
  source          Source        @relation(fields: [sourceId], references: [id])
  originalTitle   String
  translatedTitle String
  slug            String        @unique
  summary         String
  excerpt         String
  originalUrl     String        @unique
  imageUrl        String?
  category        String
  championship    String?
  country         String
  language        String
  publishedAt     DateTime
  importedAt      DateTime      @default(now())
  hash            String        @unique
  status          ArticleStatus @default(PUBLISHED)
  featured        Boolean       @default(false)
  views           Int           @default(0)
  seoTitle        String?
  seoDescription  String?

  tags ArticleTag[]

  @@index([slug])
  @@index([publishedAt])
  @@index([category])
  @@index([sourceId])
  @@index([status])
  @@index([country])
  @@index([championship])
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ImportLog {
  id          String   @id @default(cuid())
  sourceId    String?
  sourceName  String
  imported    Int      @default(0)
  skipped     Int      @default(0)
  errors      Int      @default(0)
  errorDetail String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
}
